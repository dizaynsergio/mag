# Скопируйте этот файл в .env.local и заполните значения.
# .env.local игнорируется git (правило *.local в .gitignore).

# Токен бота, полученный у @BotFather
VITE_TELEGRAM_BOT_TOKEN=1234567890:AAH-replace-me

# ID чата/группы, куда бот будет присылать заявки.
# Узнать: написать боту любое сообщение, открыть
# https://api.telegram.org/bot<ТОКЕН>/getUpdates
# и взять chat.id из ответа. У групп id с минусом, напр. -1001234567890
VITE_TELEGRAM_CHAT_ID=123456789
